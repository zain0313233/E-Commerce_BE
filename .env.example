# ============================================
# E-COMMERCE BACKEND — copy to .env
# NEVER commit .env to version control
# ============================================

# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Neon PostgreSQL (https://console.neon.tech)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Optional pool tuning
# DB_MAX_CONNECTIONS=20
# DB_IDLE_TIMEOUT=10000
# DB_CONNECTION_TIMEOUT=2000

# Supabase — Auth + Storage (https://supabase.com/dashboard)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_STORAGE_BUCKET=product-images

# Stripe (https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx

# Storefront URL (checkout redirects + password reset email)
NEXT_PUBLIC_DOMAIN=http://localhost:3000

# CORS — comma-separated frontend URLs (add production URL when deploying)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Optional: CommerceAI storefront assistant (https://platform.openai.com)
# Works without this — rule-based search still runs; with key, replies are LLM-polished.
# OPENAI_API_KEY=sk-xxxxxxxx
# OPENAI_MODEL=gpt-4o-mini
# SUPPORT_CHAT_RATE_LIMIT=30

# Optional: Tavily for image repair scripts (https://tavily.com)
# TAVILY_API_KEY=tvly-xxxxxxxx

# Optional: Google Drive product import
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_PRIVATE_KEY=
# GOOGLE_DRIVE_FOLDERID=

# Optional: Cloudinary / BunnyCDN (legacy; catalog uses Supabase Storage)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Admin seed script (npm run create:admin)
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=ChangeMe_Strong1
